#!/usr/bin/env bash

source "$HOME/.config/bash/bashrc.d/ansi-color.sh"

c0() {
    ansi::reset-color
}
c1() {
    ansi::rgb $((0x6c)) $((0x71)) $((0x89))
}
c2() {
    ansi::rgb $((0xc7)) $((0xc9)) $((0xd1))
}
c3() {
    ansi::rgb $((0x6c)) $((0x71)) $((0x89))
    ansi::bg-rgb $((0x28)) $((0x2d)) $((0x43))
}
c4() {
    ansi::rgb $((0xc7)) $((0xc9)) $((0xd1))
    ansi::bg-rgb $((0x28)) $((0x2d)) $((0x43))
}
c5() {
    ansi::rgb $((0x6c)) $((0x71)) $((0x89))
}
c6() {
    ansi::rgb $((0xc7)) $((0xc9)) $((0xd1))
}
c7() {
    ansi::rgb $((0x28)) $((0x2d)) $((0x43))
}
motd_banner()
{
cat<<-BANNER
  $(c1)    $(c0) $(c1)    $(c0) $(c1)    $(c0) $(c2)▄   $(c0) $(c2)    $(c0) $(c2)    $(c0) $(c2)    $(c0)
  $(c1)█▀▀▀$(c0) $(c1)█▀▀▀$(c0) $(c1)█▀▀▀$(c0) $(c2)█▀▀█$(c0) $(c2)█▀▀█$(c0) $(c2)█▀▀▄$(c0) $(c2)█▀▀█$(c0)
  $(c3)█   $(c0) $(c3)█   $(c0) $(c3)█   $(c0) $(c4)█  █$(c0) $(c4)█▀▀▀$(c0) $(c4)█  █$(c0) $(c4)█  █$(c0)
  $(c5)▀▀▀▀$(c0) $(c5)▀▀▀▀$(c0) $(c5)▀▀▀▀$(c0) $(c6)▀$(c7)▀▀$(c6)▀$(c0) $(c6)▀▀▀▀$(c0) $(c6)▀$(c7)▀▀$(c6)▀$(c0) $(c6)▀▀▀█$(c0)
  $(c1)    $(c0) $(c1)    $(c0) $(c1)    $(c0) $(c2)    $(c0) $(c2)    $(c0) $(c2)    $(c0) $(c2) ▀▀▀$(c0)
BANNER
}

motd_cat()
{
cat <<-CAT

   ╱|、
  (˚ˎ 。7
   |、˜〵
   じしˍ,)ノ  Hello $USER (${SSH_CLIENT%% *}). This is $HOSTNAME!

CAT
}

motd_daemon()
{
cat <<-DAEMON

     (__)
  \\\\\\'',)
    \\/  \\ ^
    .\\._/_)   Hello $USER (${SSH_CLIENT%% *}). This is $HOSTNAME!

DAEMON
}

case $((RANDOM % 3)) in
    0)
        motd_banner
        ;;
    1)
        motd_cat
        ;;
    2)
        motd_daemon
        ;;
esac

